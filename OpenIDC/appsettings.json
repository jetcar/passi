{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Elastic.Apm": "Debug"
    }
  },
  "AppSetting": {
    "SessionLength": 10,
    "EmailFrom": "sender@passi.cloud",
    "IdentityDbName": "OpenIdc",
    "DbHost": "database",
    "DbUser": "postgres",
    "DbPassword": "test1",
    "DbPort": 5432,
    "OidcClients": [
      {
        "ClientId": "SampleApp",
        "ClientSecretEnvVar": "ClientSecret",
        "DisplayName": "SampleApp client application",
        "RedirectUris": [
          "https://localhost/callback/login/local",
          "https://localhost/sampleapi/callback/login/local",
          "https://host.docker.internal/callback/login/local",
          "https://passi.cloud/callback/login/local"
        ],
        "AllowedScopes": [
          "openid",
          "profile",
          "email",
          "roles"
        ],
        "RequiresPkce": true
      },
      {
        "ClientId": "MailuId",
        "ClientSecretEnvVar": "OIDC_CLIENT_SECRET",
        "DisplayName": "mailler client application",
        "RedirectUris": [
          "https://localhost/mailler/oauth2/authorize",
          "https://host.docker.internal/mailler/oauth2/authorize",
          "https://passi.cloud/mailler/oauth2/authorize",
          "https://passi.cloud/sso/login"
        ],
        "AllowedScopes": [
          "openid",
          "profile",
          "email",
          "roles"
        ],
        "RequiresPkce": false
      },
      {
        "ClientId": "SampleApiClient",
        "ClientSecretEnvVar": "SampleApiSecret",
        "DisplayName": "Sample API client application",
        "RedirectUris": [
          "https://localhost/sampleapi/callback",
          "https://host.docker.internal/sampleapi/callback",
          "https://passi.cloud/sampleapi/callback"
        ],
        "AllowedScopes": [
          "openid",
          "profile",
          "email",
          "api"
        ],
        "RequiresPkce": false
      }
    ],
    "redis": "localhost",
    "redisPort": "6379",
    "PassiUrl": "http://192.168.0.208:5004/passiapi",
    "startRequest": "/api/auth/start",
    "checkRequest": "/api/auth/check",
    "IdentityUrlBase": "https://192.168.0.208",
    "DbSslMode": "Allow",
    "adminAccount": "",
    "projectId": "projectId",
    "IdentityCertPassword": ""
  },
  "Urls": "https://0.0.0.0:5005",
  "AllowedHosts": "*"
}